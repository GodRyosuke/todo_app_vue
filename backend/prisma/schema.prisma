generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Todo {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(256)
  category   Category @relation(fields: [categoryId], references: [id])
  categoryId Int
  is_done    Boolean
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @db.VarChar(256)
  todos Todo[]
}
